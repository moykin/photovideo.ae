{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review",
    "description": "Client reviews for completed bookings"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "booking": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::booking.booking",
      "inversedBy": "review"
    },
    "rating": { "type": "integer", "required": true, "min": 1, "max": 5 },
    "comment": { "type": "text", "maxLength": 1000 },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "provider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "isPublic": { "type": "boolean", "default": true },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    }
  }
}
