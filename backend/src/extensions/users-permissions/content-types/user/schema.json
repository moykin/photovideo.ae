{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": { "type": "string", "configurable": false },
    "password": { "type": "password", "minLength": 6, "configurable": false, "private": true },
    "resetPasswordToken": { "type": "string", "configurable": false, "private": true },
    "confirmationToken": { "type": "string", "configurable": false, "private": true },
    "confirmed": { "type": "boolean", "default": false, "configurable": false },
    "blocked": { "type": "boolean", "default": false, "configurable": false },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },

    "displayName": { "type": "string" },
    "bio": { "type": "text", "maxLength": 1000 },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "coverPhoto": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "userType": {
      "type": "enumeration",
      "enum": ["photographer", "videographer", "both", "client"],
      "default": "client"
    },
    "location": { "type": "string" },
    "city": { "type": "string", "default": "Dubai" },
    "country": { "type": "string", "default": "UAE" },
    "phone": { "type": "string" },
    "experience": { "type": "integer", "min": 0 },
    "pricePerHour": { "type": "decimal" },
    "pricePerEvent": { "type": "decimal" },
    "currency": {
      "type": "enumeration",
      "enum": ["AED", "USD"],
      "default": "AED"
    },
    "specializations": { "type": "json" },
    "languages": { "type": "json" },
    "equipment": { "type": "text" },
    "socialLinks": {
      "type": "component",
      "repeatable": false,
      "component": "shared.social-links"
    },
    "isVerified": { "type": "boolean", "default": false },
    "isAvailable": { "type": "boolean", "default": true },
    "rating": { "type": "decimal", "default": 0 },
    "totalReviews": { "type": "integer", "default": 0 },
    "completedBookings": { "type": "integer", "default": 0 },
    "slug": { "type": "uid", "targetField": "username" },

    "portfolios": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::portfolio.portfolio",
      "mappedBy": "author"
    },
    "feedPosts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::feed-post.feed-post",
      "mappedBy": "author"
    },
    "bookingsAsClient": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking.booking",
      "mappedBy": "client"
    },
    "bookingsAsProvider": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking.booking",
      "mappedBy": "provider"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    },
    "featuredUntil": {
      "type": "datetime"
    },
    "featuredOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
