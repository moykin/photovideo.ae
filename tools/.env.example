# Скопируй этот файл в .env и заполни значения

# OAuth credentials из Google Cloud Console (тип: Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# URL куда Google редиректит после авторизации
# Для локального запуска: http://localhost:8080/auth/callback
# Для сервера: https://yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:8080/auth/callback

# Случайная строка для подписи сессий (можно сгенерировать: openssl rand -hex 32)
SECRET_KEY=change-me-to-random-string
